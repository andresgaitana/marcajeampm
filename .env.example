# ── marcajeampm — variables de entorno ──────────────────────────────────────
# Copia este archivo a .env y rellena los valores. NUNCA subas .env al repo.
# En Vercel, carga estas mismas variables en Project Settings → Environment Variables.

# Supabase — proyecto propio (Project Settings → API)
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"           # llave publishable (o anon)
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role..."        # SECRETA — solo servidor, nunca al cliente

# Mismas URL/llave publishable, expuestas al cliente en build (prefijo VITE_)
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# ── Validación de selfie / anti-foto ────────────────────────────────────────
# Por DEFECTO (sin ninguna variable de abajo) la app es 100% LOCAL y GRATIS:
#   parpadeo en el navegador (liveness) + reconocimiento facial + enrolamiento
#   obligatorio + geocerca. NO llama a ninguna IA externa → costo $0.
# Las opciones de abajo son CAPAS EXTRA opcionales (detección de pantalla/foto-de-
# foto). Si no las configuras, no se usan y no se cobra nada.
#
# Opción A — Gemini (Google AI Studio, API key simple). Déjalo vacío para no usarlo.
# GEMINI_API_KEY="AIza..."
#
# Opción B (archivada) — Vertex AI vía Supabase Edge Function (service account).
# Para activarla: SELFIE_VALIDATOR=edge + cargar el secreto VERTEX_SA_JSON en
# Supabase (Edge Functions → Secrets). Ver supabase/functions/validate-selfie/README.md
# SELFIE_VALIDATOR="edge"

# Geocerca: el marcaje exige que la ubicación reportada caiga dentro del radio de
# la tienda (stores.geofence_radius_m, def. 300 m). NO se exige precisión de GPS
# (las terminales son tablets WiFi sin GPS real).

# Build de Vercel (Nitro). En Vercel ya queda fijado por vite.config.ts (preset "vercel");
# esta variable es opcional para overrides locales.
# NITRO_PRESET="vercel"
